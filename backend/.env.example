# Railway provides DATABASE_URL automatically when you add Postgres plugin
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-with-random-hex-string-32-bytes

# Your admin password (change to something secure!)
ADMIN_PASSWORD=zmienmnieprosze

# Frontend origins (comma-separated). Your GitHub Pages URL.
ALLOWED_ORIGINS=https://dominikszewczyk224180.github.io,http://localhost:3000
